{
  "name": "beamr",
  "displayName": "Beamr",
  "description": "Transfer files and entire folders securely from VSCode to any mobile device or external computer over animated QR codes—no network connection required.",
  "version": "1.0.3",
  "publisher": "abhishekverma",
  "icon": "media/icon.png",
  "homepage": "https://beamr.vrma.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/w3Abhishek/Beamr.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "beamr.sendFile",
        "title": "Share with Beamr"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "beamr.sendFile"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "mime-types": "^2.1.35"
  }
}
